# Path to the yt-dlp binary (default: "yt-dlp" on PATH)
# YTDLP_PATH=yt-dlp

# Directory OR full path to the ffmpeg binary. Leave unset to use PATH.
# On Windows you might set: FFMPEG_LOCATION=C:\ffmpeg\bin
# FFMPEG_LOCATION=

# Where temp video/audio files are written before being streamed to the browser
# DOWNLOAD_DIR=downloads

# Port for `next start` (defaults to 3000)
# PORT=3000

# ── Split deployment (UI on Vercel + engine on Railway/Render) ────────────────
# Set on the UI (Vercel) so the browser calls the engine on its own origin.
# Must be prefixed NEXT_PUBLIC_ to be exposed to the browser.
# NEXT_PUBLIC_API_BASE=https://rillix-engine.up.railway.app

# Set on the ENGINE host to restrict who may call its API (defaults to "*").
# ALLOWED_ORIGIN=https://your-ui.vercel.app
